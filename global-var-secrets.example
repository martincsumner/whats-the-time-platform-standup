# global-var-secrets.example
#
# Copy this file to global-var-secrets.txt and fill in real values before running any playbook.
#
#   cp global-var-secrets.example global-var-secrets.txt

# Do not checkin your secrets file
# Everything else is templated using Ansible Templating all paths etc. are declared in this single file.
#
# global-var-secrets.txt is listed in .gitignore and must never be committed to source control.
# All hardwired paths and credentials that vary between environments live here.

# ── CRC cluster ───────────────────────────────────────────────────────────────
# kubeadmin password for the local CRC cluster.
# Retrieve with: crc console --credentials -o json | jq -r '.clusterConfig.adminCredentials.password'
crc_password: "your-kubeadmin-password-here"

# ── Gitea ─────────────────────────────────────────────────────────────────────
# IP address and port of the local Git instance (no scheme). I happen to be using gitea locally.
# Used to construct all repo URLs: http://<gitea_host>/<gitea_username>/<repo>.git
gitea_host: "http://192.168.1.81:3000"

# Gitea login credentials.
# Used by: ArgoCD repo secret, Tekton git-clone task, clone-all-repos playbook.
gitea_username: "guser"
gitea_password: "your-gitea-password-here"

# ── Quay.io robot account ─────────────────────────────────────────────────────
# You can use any docker registry, I am using quay.io because its free for tyre kicking!
# Robot account credentials for pushing built images.
# Retrieve the token from: https://quay.io -> Account Settings -> Robot Accounts
quay_robot_username: "martin_c_sumner+whatsthetime"
quay_robot_token: "your-quay-robot-token-here"

# ── Image registry ────────────────────────────────────────────────────────────
# Fully-qualified image name (no tag or digest) pushed by the build pipeline
# and referenced in the Kustomize overlays.
quay_image: "quay.io/martin_c_sumner/whatsthetime"

# ── OpenShift cluster routing ─────────────────────────────────────────────────
# Wildcard apps domain for the CRC cluster.
# Route hosts are constructed as <env-prefix>.<crc_apps_domain>.
crc_apps_domain: "apps-crc.testing"
